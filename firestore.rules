
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FLAVORVAULT SECURITY RULES
     *
     * Enforces strict path-based ownership.
     * All user-specific data is nested under /users/{userId}.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'carolynjuba@gmail.com';
    }

    function isOwner(userId) {
      return isOwnerEmail(userId) || isAdmin();
    }

    function isOwnerEmail(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      match /pantry/{pantryIngredientId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      match /savedRecipes/{savedRecipeId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
